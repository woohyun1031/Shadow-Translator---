{
  "manifest_version": 3,
  "name": "Shadow Translator",
  "version": "1.0.0",
  "description": "Appends original text alongside Google Translation.",
  "permissions": ["storage"],
  "action": {
    "default_title": "Shadow Translator",
    "default_popup": "popup.html"
  },
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  }
}
